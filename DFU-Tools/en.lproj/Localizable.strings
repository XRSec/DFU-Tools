"About_DFU_Port_Note" = "   - Note: Host Mac (the one running this tool) should use the first port near the screen";
"About_Guide_Title" = "========== User Guide ==========";
"About_Guide_1_Title" = "1. Device Connection";
"About_Guide_1_1" = "   - Ensure your Apple Silicon device is connected to Mac via USB";
"About_Guide_1_2" = "   - Select the device to operate from the device list dropdown menu";
"About_Guide_2_Title" = "2. DFU Mode";
"About_Guide_2_1" = "   - Click the \"DFU\" button to put the device into DFU mode";
"About_Guide_2_2" = "   - The device will restart and enter DFU mode";
"About_Guide_3_Title" = "3. Restore Device";
"About_Guide_3_1" = "   - If \"Use IPSW\" checkbox is selected, first click \"Select IPSW File\" button to select firmware file";
"About_Guide_3_2" = "   - Click \"Restore\" button to start restoring device";
"About_Guide_3_3" = "   - The restore process may take several minutes, please be patient";
"About_Guide_4_Title" = "4. Revive Device (Preserve Data)";
"About_Guide_4_1" = "   - Click \"Revive\" button to restore device while preserving data";
"About_Guide_4_2" = "   - This feature requires the device to be in DFU mode";
"About_Guide_5_Title" = "5. Reboot Device";
"About_Guide_5_1" = "   - Click \"Reboot\" button to reboot device";
"About_Guide_5_2" = "   - Device will reboot from DFU mode or normal mode";
"About_Guide_6_Title" = "6. Using IPSW File";
"About_Guide_6_1" = "   - Check \"Use IPSW\" checkbox to enable IPSW file selection";
"About_Guide_6_2" = "   - Click \"Select IPSW File\" button to select firmware file";
"About_Guide_6_3" = "   - Selected file path will be displayed next to the button";
"About_Notes_Title" = "Notes:";
"About_Notes_1" = "   - Ensure important data is backed up before operating device";
"About_Notes_2" = "   - Restore operation will erase all data on device (unless using Revive)";
"About_Notes_3" = "   - Ensure using correct IPSW file version";
"About_Notes_4" = "   - Do not disconnect USB connection during operation";
"About_Support_Title" = "Technical Support:";
"About_Support_1" = "   - If encountering issues, check detailed information in output window";
"About_Support_2" = "   - Contact customer service for help";

