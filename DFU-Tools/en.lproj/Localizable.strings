"About_DFU_Port_Title" = "========== DFU Port Guide ==========";
"About_DFU_Port_M4" = "   - MacBook Air M4: Left side, second port";
"About_DFU_Port_M1_M2_M3" = "   - MacBook (Air/Pro) M1/M2/M3: Left side, first port";
